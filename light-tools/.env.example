NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=

# Production example when reverse proxied below the blog:
# NEXT_PUBLIC_SITE_URL=https://herong.info/file-tools
# NEXT_PUBLIC_BASE_PATH=/file-tools

# Future server-side task settings. Not used in phase 0/1.
ENABLE_SERVER_JOBS=false
TEMP_DIR=/tmp/light-tools
DATABASE_URL=
REDIS_URL=

# Optional: absolute FFmpeg binary path for server-side MP4 to GIF conversion.
# Example: /usr/local/bin/ffmpeg or /opt/homebrew/bin/ffmpeg
LIGHT_TOOLS_FFMPEG_PATH=

# Anonymous free quota for server-side conversions.
# MVP uses an HttpOnly anonymous visitor cookie and in-memory process counters.
LIGHT_TOOLS_FREE_CONVERSIONS=5
LIGHT_TOOLS_FREE_WINDOW_DAYS=30
LIGHT_TOOLS_DATA_DIR=/tmp/light-tools-data

# Admin console. Production must set these values.
LIGHT_TOOLS_ADMIN_PASSWORD=
LIGHT_TOOLS_ADMIN_SESSION_SECRET=

# Course member login. Production must set this to a long random value.
LIGHT_TOOLS_MEMBER_SESSION_SECRET=

# Future production upload scanning. Not used by the current MVP code yet.
ENABLE_ANTIVIRUS_SCAN=false
CLAMAV_HOST=
CLAMAV_PORT=3310

# Future WeChat Pay API v3 integration. Keep disabled until merchant credentials
# and HTTPS notify URL are ready.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_PLATFORM_CERT=
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
